{
  "name": "rate-limit-retry",
  "version": "1.0.0",
  "description": "Robust TypeScript rate limiting with exponential backoff, retry strategies, and circuit breaker patterns for production services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rate-limit",
    "retry",
    "exponential-backoff",
    "circuit-breaker",
    "throttle",
    "typescript"
